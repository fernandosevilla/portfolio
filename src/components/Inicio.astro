---
const highlights = [
    'Laravel',
    'PHP',
    'Spring Boot',
    'Java',
    '.NET',
    'C#',
    'JavaScript',
    'SQL Server',
    'Docker',
    'Git',
    'Tests',
];

const socialLinks = [
    {
        label: 'GitHub',
        href: 'https://github.com/fernandosevilla/',
    },
    {
        label: 'LinkedIn',
        href: 'https://www.linkedin.com/in/fernandosevillaespinosa/',
    },
]
---

<section
	id="inicio"
	class="grid min-h-[calc(100vh-7rem)] gap-12 py-12 lg:items-center lg:py-20 lg:grid-cols-[1.15fr_0.85fr]"
>
	<div class="mt-6 justify-self-center lg:col-span-2 lg:mt-0">
		<div
			class="inline-flex items-center gap-2 rounded-full border border-(--color-border)
				bg-(--color-surface) px-4 py-2 text-sm font-medium text-(--color-muted)"
		>
			<span class="size-2 rounded-full bg-(--color-accent)"></span>
			Disponible para nuevos proyectos
		</div>
	</div>

	<div>
		<h1
			class="max-w-4xl text-center text-4xl font-bold tracking-tight text-(--color-text)
				sm:text-5xl lg:text-6xl"
		>
            Construyo aplicaciones y herramientas que hacen el trabajo más sencillo.
		</h1>
        
		<p class="mt-6 max-w-2xl text-lg leading-8 text-(--color-muted) text-center">
            Soy Fernando Sevilla, desarrollador de software. Me gusta crear productos
            bien pensados, fáciles de mantener y conectados con las necesidades reales
            de cada proyecto.
		</p>

		<div class="mt-8 flex flex-col md:items-center md:justify-center gap-3 sm:flex-row">
			<a
				href="#proyectos"
				class="inline-flex items-center justify-center rounded-2xl bg-(--color-accent)
					px-6 py-3 text-base font-semibold text-(--color-accent-foreground)
					transition hover:opacity-90"
			>
				Ver proyectos
			</a>

			<a
				href="#contacto"
				class="inline-flex items-center justify-center rounded-2xl border border-(--color-border)
					bg-(--color-surface) px-6 py-3 text-base font-semibold text-(--color-text)
					transition hover:bg-(--color-hover)"
			>
				Contactar
			</a>
		</div>

		<div class="mt-10 flex flex-wrap gap-3 items-center">
			{
				highlights.map((item) => (
					<span
						class="rounded-full border border-(--color-border) bg-(--color-surface-muted)
							px-3 py-1 text-sm font-medium text-(--color-muted)"
					>
						{item}
					</span>
				))
			}
		</div>
	</div>

    <aside
        class="rounded-3xl border border-(--color-border) bg-(--color-surface)
            p-6 shadow-2xl shadow-black/5"
    >
        <div class="space-y-1">
            <p class="text-sm font-medium text-(--color-muted)">Enfoque</p>
            <h2 class="text-2xl font-bold tracking-tight text-(--color-text)">
                Producto, código y negocio.
            </h2>
        </div>

        <div class="mt-6 grid gap-3">
            <div class="rounded-2xl bg-(--color-surface-muted) p-4">
                <p class="text-sm font-semibold text-(--color-text)">01 · Crear</p>
                <p class="mt-1 text-sm text-(--color-muted)">
                    Aplicaciones web desde cero.
                </p>
            </div>

            <div class="rounded-2xl bg-(--color-surface-muted) p-4">
                <p class="text-sm font-semibold text-(--color-text)">02 · Integrar</p>
                <p class="mt-1 text-sm text-(--color-muted)">
                    APIs, servicios externos y sistemas internos.
                </p>
            </div>

            <div class="rounded-2xl bg-(--color-surface-muted) p-4">
                <p class="text-sm font-semibold text-(--color-text)">03 · Mantener</p>
                <p class="mt-1 text-sm text-(--color-muted)">
                    Código existente, mejoras e incidencias reales.
                </p>
            </div>
        </div>

        <div class="mt-6 border-t border-(--color-border) pt-5">
            <p
                class="text-sm font-medium text-(--color-muted) text-center"
            >
                También puedes encontrarme en:
            </p>

            <div class="mt-3 grid grid-cols-2 gap-3">
                {
                    socialLinks.map((link) => (
                        <a
                            href={link.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center justify-center rounded-xl border border-(--color-border)
                                px-4 py-3 text-center text-sm font-semibold text-(--color-accent-content)
                                transition hover:bg-(--color-accent-soft)"
                        >
                            {link.label}
                        </a>
                    ))
                }
            </div>
        </div>
    </aside>
</section>