---
const workingPoints = [
    {
        title: 'Entender antes de construir',
        description:
            'Me gusta comprender bien el problema, el contexto y las necesidades reales antes de ponerme a escribir código.',
    },
    {
        title: 'Mejora e innovación',
        description:
            'Busco formas de mejorar lo que ya existe, probar nuevas ideas y aplicar tecnología con criterio para crear soluciones más útiles, ágiles y eficientes.',
    },
    {
        title: 'Mentalidad práctica',
        description:
            'Valoro que el software funcione bien, sea útil y ayude de verdad en el día a día de las personas o empresas que lo usan.',
    },
];

const highlights = [
    'Desarrollo web',
    'APIs',
    'Integración de sistemas',
    'Software empresarial',
    'Mantenimiento',
    'Mejora continua',
];
---

<section id="sobre-mi" class="py-24">
    <div class="grid gap-14 lg:grid-cols-[18rem_1fr] lg:items-start xl:gap-20">
        <div>
            <p class="mb-3 text-sm font-medium uppercase tracking-[0.25em] text-(--color-muted)">
                Sobre mí
            </p>

            <h2 class="text-3xl font-semibold tracking-tight text-(--color-text) sm:text-4xl">
                Un poco más sobre mí
            </h2>

            <p class="mt-4 max-w-xl text-base leading-7 text-(--color-muted)">
                Más allá de las tecnologías, me interesa crear software que tenga sentido,
                que sea útil y que pueda seguir creciendo con el tiempo.
            </p>
        </div>

        <div class="space-y-6">
            <article
                class="rounded-3xl border border-(--color-border) bg-(--color-surface)
                    p-6 shadow-sm lg:p-8"
            >
                <div class="max-w-3xl">
                    <h3 class="text-2xl font-semibold tracking-tight text-(--color-text) sm:text-3xl">
                        ¡Hola! Soy Fernando
                    </h3>

                    <div class="mt-6 space-y-5 text-base leading-8 text-(--color-muted)">
                        <p>
                            Me gusta trabajar cerca del producto, entender qué se necesita y
                            convertirlo en soluciones sencillas, útiles y mantenibles.
                        </p>

                        <p>
                            He trabajado en proyectos de gestión empresarial, recursos humanos,
                            integración de sistemas y mantenimiento de aplicaciones existentes,
                            tanto en entorno web como en software de escritorio.
                        </p>

                        <p>
                            Actualmente estoy enfocando mi camino profesional hacia el desarrollo
                            web, el backend, las APIs y los proyectos donde pueda aportar desde el
                            análisis hasta la implementación.
                        </p>
                    </div>

                    <div class="mt-8 flex flex-wrap gap-2">
                        {
                            highlights.map((item) => (
                                <span
                                    class="rounded-full border border-(--color-border)
                                        bg-(--color-surface-muted) px-3 py-1 text-sm font-medium
                                        text-(--color-muted)"
                                >
                                    {item}
                                </span>
                            ))
                        }
                    </div>
                </div>
            </article>

            <div class="grid gap-6 md:grid-cols-3">
                {
                    workingPoints.map((point) => (
                        <article
                            class="rounded-3xl border border-(--color-border) bg-(--color-surface)
                                p-6 shadow-sm transition hover:-translate-y-1 hover:border-(--color-text)/20"
                        >
                            <h3 class="text-lg font-semibold text-(--color-text)">
                                {point.title}
                            </h3>

                            <p class="mt-3 text-sm leading-6 text-(--color-muted)">
                                {point.description}
                            </p>
                        </article>
                    ))
                }
            </div>
        </div>
    </div>
</section>
