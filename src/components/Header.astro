---
const projects = [
	{
		title: "Portfolio personal",
		description: "Astro, Tailwind y contenido en Markdown",
		href: "/proyectos/portfolio",
	},
	{
		title: "5RRHH",
		description: "Aplicación web de recursos humanos",
		href: "/proyectos/5rrhh",
	},
	{
		title: "API a3factura",
		description: "Integración API con ERP interno",
		href: "/proyectos/api-a3factura",
	},
];
---

<header
	class="fixed inset-x-0 top-0 z-50 border-b border-(--color-border) bg-(--color-header-bg) backdrop-blur-xl"
>
	<nav
		class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8"
	>
		<a
			href="/" 
			class="flex items-center gap-3"
		>
			<span class="text-xl font-bold tracking-tight text-(--color-text)">
				Fernando <span class="text-(--color-accent-content)">Sevilla</span>
			</span>
		</a>

		<div class="hidden items-center gap-8 lg:flex">
			<a
				href="#inicio"
				class="text-base font-medium text-(--color-muted) transition hover:text-(--color-text)"
			>
				Inicio
			</a>

			<a
				href="#experiencia"
				class="text-base font-medium text-(--color-muted) transition hover:text-(--color-text)"
			>
				Experiencia
			</a>

			<div class="group relative">
				<a
					href="#proyectos"
					class="flex items-center gap-1 text-base font-medium text-(--color-muted) transition hover:text-(--color-text)"
					aria-label="Ir a la sección de proyectos"
				>
					Proyectos

					<svg
						class="size-4 transition group-hover:rotate-180 group-focus-within:rotate-180"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						aria-hidden="true"
						focusable="false"
					>
						<path d="m6 9 6 6 6-6"></path>
					</svg>
				</a>

				<div
					class="invisible pointer-events-none absolute left-1/2 top-full w-80 -translate-x-1/2 pt-4 opacity-0
						transition delay-300 duration-200 group-hover:visible group-hover:pointer-events-auto 
						group-hover:opacity-100 group-hover:delay-0 group-focus-within:visible 
						group-focus-within:pointer-events-auto group-focus-within:opacity-100 group-focus-within:delay-0"
				>
					<div
						class="translate-y-2 rounded-2xl border border-(--color-border) bg-(--color-surface) p-2 shadow-2xl 
						transition duration-200 group-hover:translate-y-0 group-focus-within:translate-y-0"
					>
						{
							projects.map((project) => (
								<a
									href={project.href}
									class="block rounded-xl px-4 py-3 transition hover:bg-(--color-hover)"
									aria-label={`Ver detalles del proyecto ${project.title}`}
								>
									<span class="block text-sm font-semibold text-(--color-text)">
										{project.title}
									</span>

									<span class="mt-1 block text-sm text-(--color-muted)">
										{project.description}
									</span>
								</a>
							))
						}

						<a
							href="#proyectos"
							class="mt-1 block rounded-xl border border-(--color-border) px-4 py-3 text-center text-sm 
								font-semibold text-(--color-accent-content) transition hover:bg-(--color-accent-soft)"
							aria-label="Ver todos los proyectos"
						>
							Ver todos los proyectos
						</a>
					</div>
				</div>
			</div>

			<a
				href="#sobre-mi"
				class="text-base font-medium text-(--color-muted) transition hover:text-(--color-text)"
			>
				Sobre mí
			</a>

			<a
				href="#contacto"
				class="text-base font-medium text-(--color-muted) transition hover:text-(--color-text)"
			>
				Contacto
			</a>
		</div>

		<div class="flex items-center gap-3">
			<div
				class="hidden items-center rounded-2xl border border-(--color-border) bg-(--color-surface-muted) p-1 lg:flex"
				aria-label="Selector de tema"
			>
				<button
					type="button"
					data-theme-toggle="light"
					class="theme-toggle grid size-9 place-items-center rounded-xl text-(--color-muted) transition
						hover:text-(--color-text)"
					aria-label="Usar tema claro"
					aria-pressed="false"
				>
					<svg
						class="size-5"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<circle cx="12" cy="12" r="4"></circle>
						<path d="M12 2v2"></path>
						<path d="M12 20v2"></path>
						<path d="m4.93 4.93 1.41 1.41"></path>
						<path d="m17.66 17.66 1.41 1.41"></path>
						<path d="M2 12h2"></path>
						<path d="M20 12h2"></path>
						<path d="m6.34 17.66-1.41 1.41"></path>
						<path d="m19.07 4.93-1.41 1.41"></path>
					</svg>
				</button>

				<button
					type="button"
					data-theme-toggle="dark"
					class="theme-toggle grid size-9 place-items-center rounded-xl text-(--color-muted) transition
						hover:text-(--color-text)"
					aria-label="Usar tema oscuro"
					aria-pressed="false"
				>
					<svg
						class="size-5"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path
							d="M20.99 12.74A8.99 8.99 0 1 1 11.26 3.01a7 7 0 0 0 9.73 9.73Z"
						></path>
					</svg>
				</button>

				<button
					type="button"
					data-theme-toggle="system"
					class="theme-toggle grid size-9 place-items-center rounded-xl text-(--color-muted) transition
						hover:text-(--color-text)"
					aria-label="Usar tema del sistema"
					aria-pressed="false"
				>
					<svg
						class="size-5"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect width="18" height="12" x="3" y="4" rx="2"></rect>
						<path d="M8 20h8"></path>
						<path d="M12 16v4"></path>
					</svg>
				</button>
			</div>

			<button
				id="menu-button"
				type="button"
				class="grid size-11 place-items-center rounded-2xl border border-(--color-border) bg-(--color-surface-muted)
					text-(--color-muted) transition hover:text-(--color-text) lg:hidden"
				aria-label="Abrir menú"
				aria-expanded="false"
			>
				<svg
					id="menu-open-icon"
					class="size-6"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
				>
					<path d="M4 7h16M4 12h16M4 17h16"></path>
				</svg>

				<svg
					id="menu-close-icon"
					class="hidden size-6"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
				>
					<path d="M6 6l12 12M18 6 6 18"></path>
				</svg>
			</button>
		</div>
	</nav>

	<div
		id="mobile-menu"
		class="hidden max-h-[calc(100dvh-5rem)] overflow-y-auto overscroll-contain border-t border-(--color-border) 
			bg-(--color-header-bg) px-4 py-4 pb-[calc(1rem+env(safe-area-inset-bottom))]
			shadow-2xl backdrop-blur-xl lg:hidden"
	>
		<div class="mx-auto flex max-w-7xl flex-col gap-2">
			<a
				href="#inicio"
				class="rounded-xl px-4 py-3 text-base font-medium text-(--color-muted) transition
				hover:bg-(--color-hover) hover:text-(--color-text)"
			>
				Inicio
			</a>

			<a
				href="#experiencia"
				class="rounded-xl px-4 py-3 text-base font-medium text-(--color-muted) transition
					hover:bg-(--color-hover) hover:text-(--color-text)"
			>
				Experiencia
			</a>

			<details
				class="group rounded-xl px-4 py-3 text-base font-medium text-(--color-muted)"
			>
				<summary
					class="flex cursor-pointer list-none items-center justify-between transition hover:text-(--color-text)"
				>
					Proyectos

					<svg
						class="size-4 transition group-open:rotate-180"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
					>
						<path d="m6 9 6 6 6-6"></path>
					</svg>
				</summary>

				<div class="mt-3 space-y-2">
					{
						projects.map((project) => (
							<a
								href={project.href}
								class="block rounded-xl bg-(--color-surface-muted) px-4 py-3 transition hover:bg-(--color-hover)"
								aria-label={`Ver detalles del proyecto ${project.title}`}
							>
								<span class="block text-sm font-semibold text-(--color-text)">
									{project.title}
								</span>

								<span class="mt-1 block text-sm text-(--color-muted)">
									{project.description}
								</span>
							</a>
						))
					}

					<a
						href="#proyectos"
						class="block rounded-xl border border-(--color-border) px-4 py-3 text-center text-sm
							font-semibold text-(--color-accent-content) transition hover:bg-(--color-accent-soft)"
						aria-label="Ver todos los proyectos"
					>
						Ver todos los proyectos
					</a>
				</div>
			</details>

			<a
				href="#sobre-mi"
				class="rounded-xl px-4 py-3 text-base font-medium text-(--color-muted) transition
					hover:bg-(--color-hover) hover:text-(--color-text)"
			>
				Sobre mí
			</a>

			<a
				href="#contacto"
				class="rounded-xl px-4 py-3 text-base font-medium text-(--color-muted) transition
					hover:bg-(--color-hover) hover:text-(--color-text)"
			>
				Contacto
			</a>

			<div class="mt-3 border-t border-(--color-border) pt-4">
				<div class="mb-3 px-4 text-xs font-semibold uppercase tracking-[0.2em] text-(--color-muted)">
					Tema
				</div>
				<div class="align-center flex justify-center">
					<div
						class="flex w-fit items-center rounded-2xl border border-(--color-border)
							bg-(--color-surface-muted) p-1"
						aria-label="Selector de tema móvil"
					>
						<button
							type="button"
							data-theme-toggle="light"
							class="theme-toggle grid size-10 place-items-center rounded-xl text-(--color-muted)
								transition hover:text-(--color-text)"
							aria-label="Usar tema claro"
							aria-pressed="false"
						>
							<svg
								class="size-5"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.8"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<circle cx="12" cy="12" r="4"></circle>
								<path d="M12 2v2"></path>
								<path d="M12 20v2"></path>
								<path d="m4.93 4.93 1.41 1.41"></path>
								<path d="m17.66 17.66 1.41 1.41"></path>
								<path d="M2 12h2"></path>
								<path d="M20 12h2"></path>
								<path d="m6.34 17.66-1.41 1.41"></path>
								<path d="m19.07 4.93-1.41 1.41"></path>
							</svg>
						</button>

						<button
							type="button"
							data-theme-toggle="dark"
							class="theme-toggle grid size-10 place-items-center rounded-xl text-(--color-muted)
								transition hover:text-(--color-text)"
							aria-label="Usar tema oscuro"
							aria-pressed="false"
						>
							<svg
								class="size-5"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.8"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									d="M20.99 12.74A8.99 8.99 0 1 1 11.26 3.01a7 7 0 0 0 9.73 9.73Z"
								></path>
							</svg>
						</button>

						<button
							type="button"
							data-theme-toggle="system"
							class="theme-toggle grid size-10 place-items-center rounded-xl text-(--color-muted) 
								transition hover:text-(--color-text)"
							aria-label="Usar tema del sistema"
							aria-pressed="false"
						>
							<svg
								class="size-5"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.8"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
								focusable="false"
							>
								<rect width="18" height="12" x="3" y="4" rx="2"></rect>
								<path d="M8 20h8"></path>
								<path d="M12 16v4"></path>
							</svg>
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
</header>

<script>
	const menuButton = document.getElementById("menu-button");
	const mobileMenu = document.getElementById("mobile-menu");
	const openIcon = document.getElementById("menu-open-icon");
	const closeIcon = document.getElementById("menu-close-icon");

	menuButton?.addEventListener("click", () => {
		const isOpen = mobileMenu?.classList.toggle("hidden") === false;

		menuButton.setAttribute("aria-expanded", String(isOpen));
		openIcon?.classList.toggle("hidden", isOpen);
		closeIcon?.classList.toggle("hidden", !isOpen);
	});

	mobileMenu?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => {
			mobileMenu.classList.add("hidden");
			menuButton?.setAttribute("aria-expanded", "false");
			openIcon?.classList.remove("hidden");
			closeIcon?.classList.add("hidden");
		});
	});

	type ThemeMode = "light" | "dark" | "system";
	type ResolvedTheme = "light" | "dark";

	const themeButtons = document.querySelectorAll<HTMLButtonElement>(
		"[data-theme-toggle]",
	);

	const systemThemeQuery = window.matchMedia("(prefers-color-scheme: dark)");

	function isThemeMode(value: unknown): value is ThemeMode {
		return value === "light" || value === "dark" || value === "system";
	}

	function getSavedTheme(): ThemeMode {
		const storedTheme = localStorage.getItem("theme");

		return isThemeMode(storedTheme) ? storedTheme : "system";
	}

	function resolveTheme(theme: ThemeMode): ResolvedTheme {
		if (theme === "system") {
			return systemThemeQuery.matches ? "dark" : "light";
		}

		return theme;
	}

	function applyTheme(theme: ThemeMode): void {
		const resolvedTheme = resolveTheme(theme);

		document.documentElement.dataset.theme = resolvedTheme;
		document.documentElement.dataset.themeMode = theme;

		localStorage.setItem("theme", theme);

		themeButtons.forEach((button) => {
			const isActive = button.dataset.themeToggle === theme;

			button.setAttribute("data-active", String(isActive));
			button.setAttribute("aria-pressed", String(isActive));
		});
	}

	applyTheme(getSavedTheme());

	themeButtons.forEach((button) => {
		button.addEventListener("click", () => {
			const theme = button.dataset.themeToggle;

			if (!isThemeMode(theme)) return;

			applyTheme(theme);
		});
	});

	systemThemeQuery.addEventListener("change", () => {
		const currentTheme = getSavedTheme();

		if (currentTheme === "system") {
			applyTheme("system");
		}
	});
</script>
