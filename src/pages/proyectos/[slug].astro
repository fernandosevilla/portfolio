---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProjectGallery from '../../components/projects/ProjectGallery.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');

	return projects.map((project) => ({
		params: {
			slug: project.data.slug,
		},
		props: {
			project,
		},
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);

const externalLinksCount = [
	project.data.demoUrl,
	project.data.repositoryUrl,
].filter(Boolean).length;

const hasExternalLinks = externalLinksCount > 0;
const hasMultipleExternalLinks = externalLinksCount > 1;
---

<Layout
	title={`${project.data.title} | Fernando Sevilla`}
	description={project.data.description}
>
	<main class="px-4 pt-32 pb-24 sm:px-6 lg:px-8">
		<article class="mx-auto max-w-4xl">
			<a
				href="/#proyectos"
				class="mb-10 inline-flex items-center gap-2 text-sm font-semibold
					text-(--color-muted) transition hover:text-(--color-text)"
			>
				<svg
					class="size-4"
					viewBox="0 0 24 24"
					fill="none"
					aria-hidden="true"
				>
					<path
						d="M19 12H5m6 6-6-6 6-6"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					/>
				</svg>

				Volver a proyectos
			</a>

			<header
				class="rounded-3xl border border-(--color-border) bg-(--color-surface)
					p-6 shadow-sm sm:p-8 lg:p-10"
			>
				<p class="mb-3 text-sm font-medium uppercase tracking-[0.25em] text-(--color-muted)">
					Proyecto
				</p>

				<h1 class="text-4xl font-bold tracking-tight text-(--color-text) sm:text-5xl">
					{project.data.title}
				</h1>

				<p class="mt-6 text-lg leading-8 text-(--color-muted)">
					{project.data.description}
				</p>

				<div class="mt-8 flex flex-wrap gap-2">
					{project.data.technologies.map((technology) => (
						<span
							class="rounded-full border border-(--color-border)
								bg-(--color-surface-muted) px-3 py-1 text-sm font-medium
								text-(--color-muted)"
						>
							{technology}
						</span>
					))}
				</div>

				{hasExternalLinks && (
					<div
						class:list={[
							'mt-8 grid gap-3',
							hasMultipleExternalLinks && 'sm:grid-cols-2',
						]}
					>
						{project.data.demoUrl && (
							<a
								href={project.data.demoUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="inline-flex w-full items-center justify-center gap-2 rounded-xl
									bg-(--color-accent) px-4 py-2.5 text-sm font-semibold
									text-(--color-accent-foreground) transition hover:opacity-90"
							>
								Ver demo

								<svg
									class="size-4"
									viewBox="0 0 24 24"
									fill="none"
									aria-hidden="true"
								>
									<path
										d="M7 17 17 7m0 0H9m8 0v8"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
									/>
								</svg>
							</a>
						)}

						{project.data.repositoryUrl && (
							<a
								href={project.data.repositoryUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="inline-flex w-full items-center justify-center gap-2 rounded-xl
									border border-(--color-border) bg-(--color-surface-muted)
									px-4 py-2.5 text-sm font-semibold text-(--color-muted)
									transition hover:bg-(--color-hover) hover:text-(--color-text)"
							>
								Ver repositorio

								<svg
									class="size-4"
									viewBox="0 0 24 24"
									fill="currentColor"
									aria-hidden="true"
								>
									<path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.93.58.11.79-.25.79-.56v-2.02c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.74 2.67 1.24 3.32.95.1-.74.4-1.24.72-1.52-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.15 1.18A10.9 10.9 0 0 1 12 6.17c.97 0 1.95.13 2.86.39 2.18-1.49 3.14-1.18 3.14-1.18.62 1.59.23 2.76.11 3.05.74.8 1.18 1.83 1.18 3.09 0 4.42-2.69 5.39-5.25 5.68.41.35.77 1.04.77 2.1v3.11c0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
								</svg>
							</a>
						)}
					</div>
				)}
			</header>

            <ProjectGallery
                slug={project.data.slug}
                title={project.data.title}
                cover={project.data.cover}
                coverAlt={project.data.coverAlt}
                gallery={project.data.gallery}
            />

			<div class="project-content mt-14">
				<Content />
			</div>
		</article>
	</main>
</Layout>

<style>
	.project-content {
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.8;
	}

	.project-content :global(h2) {
		margin-top: 3rem;
		margin-bottom: 1rem;
		color: var(--color-text);
		font-size: clamp(1.5rem, 2vw, 2rem);
		font-weight: 700;
		letter-spacing: -0.03em;
	}

	.project-content :global(h3) {
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		color: var(--color-text);
		font-size: 1.25rem;
		font-weight: 700;
	}

	.project-content :global(p) {
		margin-top: 1rem;
	}

	.project-content :global(ul) {
		margin-top: 1rem;
		padding-left: 1.25rem;
	}

	.project-content :global(li) {
		margin-top: 0.5rem;
		padding-left: 0.25rem;
	}

	.project-content :global(li::marker) {
		color: var(--color-accent);
	}

	.project-content :global(strong) {
		color: var(--color-text);
		font-weight: 700;
	}

	.project-content :global(a) {
		color: var(--color-accent-content);
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}

	.project-content :global(code) {
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
		background: var(--color-surface-muted);
		padding: 0.15rem 0.35rem;
		color: var(--color-text);
		font-size: 0.9em;
	}

	.project-content :global(blockquote) {
		margin-top: 1.5rem;
		border-left: 3px solid var(--color-accent);
		padding-left: 1rem;
		color: var(--color-muted);
	}
</style>